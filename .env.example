# Salin file ini menjadi ".env" (untuk vercel dev) lalu isi API key kamu.
# JANGAN commit file ".env" yang sudah berisi key asli ke git.

# API key dari Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Opsional: override urutan model fallback (dipisah koma, dicoba berurutan).
# Default (kalau kosong): gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.5-flash
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.5-flash
